# LTA DataMall — register at:
# https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
# Keys issued within 1–2 business days
LTA_ACCOUNT_KEY=your_lta_account_key_here

# OneMap — register at:
# https://www.onemap.gov.sg/apidocs/
# Immediate — no waiting period
# Server handles token generation and refresh automatically
ONEMAP_EMAIL=your_onemap_email@example.com
ONEMAP_PASSWORD=your_onemap_password_here
